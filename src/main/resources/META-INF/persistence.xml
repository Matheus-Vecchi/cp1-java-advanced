<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="cp1-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>model.Funcionario</class>
        <class>model.FuncionarioSenior</class>
        <class>model.FuncionarioComMeta</class>
        <class>model.FuncionarioPj</class>

        <properties>
            <!-- Conectando banco oracle, trocar RM e senha -->
            <property name="jakarta.persistence.jdbc.driver"   value="oracle.jdbc.OracleDriver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:oracle:thin:@oracle.fiap.com.br:1521:ORCL"/>
            <property name="jakarta.persistence.jdbc.user"     value="RM123456"/>
            <property name="jakarta.persistence.jdbc.password" value="ddmmaa"/>

            <!-- Hibernate -->
            <property name="hibernate.dialect"          value="org.hibernate.dialect.OracleDialect"/>
            <!-- update: cria/altera tabelas automaticamente -->
            <property name="hibernate.hbm2ddl.auto"    value="update"/>
            <!-- Exibe os SQLs gerados pelo Hibernate no console -->
            <property name="hibernate.show_sql"         value="true"/>
            <property name="hibernate.format_sql"       value="true"/>
        </properties>
    </persistence-unit>

</persistence>
